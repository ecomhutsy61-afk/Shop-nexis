generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Float
  image       String
  category    String
  createdAt   DateTime @default(now())

  OrderItem   OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  email         String
  address       String      @db.Text
  totalAmount   Float
  createdAt     DateTime    @default(now())

  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  productId String
  quantity  Int
  price     Float
  orderId   String

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
  createdAt DateTime @default(now())
}
